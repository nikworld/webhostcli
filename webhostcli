ensure_webhostcli_dependencies(){
  # Kept deliberately small for an adopted/legacy server: do not alter hosting services.
  simulated && return 0
  local packages=()
  cmd_exists sqlite3 || packages+=(sqlite3)
  cmd_exists python3 || packages+=(python3)
  ((${#packages[@]} == 0)) && return 0
  cmd_exists apt-get || die "$EXIT_DEPENDENCY" "missing required commands: ${packages[*]} (install them manually)"
  note "Installing missing WebhostCLI dependency: ${packages[*]}"
  apt-get update
  DEBIAN_FRONTEND=noninteractive apt-get install -y "${packages[@]}"
}
install_cmd(){ local bootstrap=0 adopt=0 repair=0; while (($#)); do case "$1" in --bootstrap) bootstrap=1;; --adopt-existing) adopt=1;; --repair) repair=1;; *) die 2 "unknown install option: $1";; esac; shift; done; require_root; if [[ -f "$BOOTSTRAP_MARKER" && -f "$PLATFORM_ENV" ]]; then note 'Existing hosting bootstrap detected.'; note 'Reusing installed infrastructure.'; elif ! simulated && { cmd_exists docker || cmd_exists nginx; } && (( !adopt && !bootstrap )); then die 5 'Docker or Nginx exists without a bootstrap marker; rerun with --adopt-existing after reviewing the server'; elif ((bootstrap)) && ! simulated && [[ "${CONFIRM_FRESH_SERVER:-}" != YES ]]; then die 7 'fresh bootstrap requires CONFIRM_FRESH_SERVER=YES'; fi
 if ((bootstrap)) && ! simulated && [[ ! -f "$BOOTSTRAP_MARKER" ]]; then bootstrap_fresh; fi
 ensure_webhostcli_dependencies; load_platform; mkdirs; init_db; write_templates; install_units; if [[ -f "$(path /etc/hosting-platform/accounts.tsv)" ]]; then import_existing; fi
 if [[ "$(readlink -f "$0")" != "$(readlink -f "$BIN" 2>/dev/null || true)" ]]; then install -D -m 0750 "$0" "$BIN"; fi; printf '%s\n' "$VERSION" >"$LIB/version"; audit '' install success; note "WebhostCLI $VERSION installed. Run: sudo webhostcli doctor"; }
uninstall_cmd(){ local purge=0; [[ "${1:-}" == --purge-all ]] && purge=1; require_root; if ((purge)); then [[ "${WEBHOSTCLI_CONFIRM_PURGE:-}" == DESTROY_HOSTING_DATA ]] || die 2 'set WEBHOSTCLI_CONFIRM_PURGE=DESTROY_HOSTING_DATA to purge all hosting data'; rm -rf -- "$CUSTOMER_ROOT" "$SRV/backups" "$DB"; fi; [[ -n "$ROOT" ]] || systemctl disable --now webhostcli-metrics.timer 2>/dev/null || true; rm -f "$BIN" "$(path /etc/systemd/system/webhostcli-metrics.service)" "$(path /etc/systemd/system/webhostcli-metrics.timer)"; rm -rf -- "$LIB" "$ETC"; note 'WebhostCLI management components removed; hosting infrastructure was preserved.'; }
upgrade_cmd(){ local source="${1:-}"; [[ -n "$source" ]] || die "$EXIT_USAGE" 'usage: webhostcli upgrade /path/to/new/webhostcli'; [[ -f "$source" ]] || die "$EXIT_NOT_FOUND" 'upgrade source not found'; bash "$source" install --repair; }

interactive(){ while true; do cat <<'EOF'

WebhostCLI

1. Create account
2. Log in to account container
3. List accounts
4. Start account
5. Stop account
6. Delete account
7. System check
0. Exit
EOF
 read -r -p 'Select: ' n; case "$n" in
  1) read -r -p 'Account name: ' a; read -r -p 'Domain: ' d; create_account "$a" "$d";;
  2) read -r -p 'Account name: ' a; shell_cmd "$a";;
  3) list_accounts;; 4) read -r -p 'Account name: ' a; account_service start "$a";;
  5) read -r -p 'Account name: ' a; account_service stop "$a";;
  6) read -r -p 'Account name: ' a; echo "Deletion is protected. Review: webhostcli account delete $a";;
  7) doctor;; 0) return;; *) echo 'Choose a number from the menu.';; esac; done; }
help(){ cat <<'EOF'
WebhostCLI 1.0.0
The normal workflow is deliberately small:

  webhostcli account create ACCOUNT DOMAIN
  webhostcli login ACCOUNT
  webhostcli account list
  webhostcli account start|stop|restart ACCOUNT
  webhostcli account delete ACCOUNT

`login` opens an isolated shell in that account's PHP container as its own UID.
The container already has PHP, Composer, Git, Node.js, npm, common PHP extensions,
and a private MySQL database connection. Install Laravel, CodeIgniter, WordPress,
or a plain PHP application from that shell.

Administration: install [--bootstrap|--adopt-existing|--repair], doctor, version,
backup, logs, usage, security, domain, ssl, database, and sftp remain available for
server administrators. Run `webhostcli help` after an administrator command for details.
EOF
}
main(){ local first="${1:-}"; case "$first" in install) shift; install_cmd "$@"; return;; upgrade) shift; upgrade_cmd "$@"; return;; uninstall) shift; uninstall_cmd "$@"; return;; version|--version) echo "$VERSION"; return;; help|-h|--help) help; return;; esac
 [[ -n "$first" ]] || { init_db; load_platform; interactive; return; }; init_db; load_platform
 case "$first" in
 doctor) doctor;; metrics-collect) collect_metrics;;
 account) shift; local sub="${1:-}"; shift || true; case "$sub" in list) [[ "${1:-}" == --json ]] && JSON=true; list_accounts;; show) local a="$1"; [[ "${2:-}" == --json ]] && JSON=true; show_account "$a";; create) create_account "$@";; start|stop|restart) account_service "$sub" "$1";; suspend|unsuspend|suspend-web|unsuspend-web|suspend-sftp|unsuspend-sftp|suspend-database|unsuspend-database) local mode=full; case "$sub" in *-web) mode=web;; *-sftp) mode=sftp;; *-database) mode=database;; esac; local reason=; [[ "${2:-}" == --reason ]] && reason="$3"; [[ "$sub" == suspend* ]] && suspend_account "$1" "$mode" "$reason" || unsuspend_account "$1" "$mode";; credentials) check_account "$1"; require_root; echo "SFTP username: $1"; echo "SFTP password: $(read_secret "$1" SFTP_PASSWORD)"; echo "Database password: $(read_secret "$1" DB_PASSWORD)";; repair) check_account "$1"; render_account "$1"; nginx_test_reload; compose "$1" up -d;; verify) check_account "$1"; compose "$1" config; [[ -f "$ETC/nginx/$1.conf" ]] || die 6 'missing nginx config'; echo OK;; logs) logs_cmd tail "$1";; containers) check_account "$1"; compose "$1" ps;; import-existing) import_existing;; delete) local a="$1"; check_account "$a"; [[ "${2:-}" == --permanent ]] && { [[ "${WEBHOSTCLI_CONFIRM_DELETE:-}" == "$a" ]] || die 2 "set WEBHOSTCLI_CONFIRM_DELETE=$a to confirm permanent deletion"; compose "$a" down; rm -rf -- "$(account_dir "$a")"; db "DELETE FROM accounts WHERE account='$(sql_escape "$a")';"; } || { echo "Deletion summary for $a:"; show_account "$a"; echo "Set WEBHOSTCLI_CONFIRM_DELETE=$a then rerun with --permanent to delete."; };;
 *) die 2 'unknown account command';; esac;;
 domain) shift; domain_cmd "$@";; ssl) shift; ssl_cmd "$@";; sftp) shift; sftp_cmd "$@";; database) shift; database_cmd "$@";; usage) shift; usage_cmd "$@";; limits) shift; limits_cmd "$@";; backup) shift; backup_cmd "$@";; php) shift; php_cmd "$@";; login|shell) shift; shell_cmd "$@";; composer) shift; composer_cmd "$@";; cron) shift; cron_cmd "$@";; logs) shift; logs_cmd "$@";; service) shift; service_cmd "$@";; server) shift; server_cmd "$@";; security) shift; security_cmd "$@";; *) die 2 "unknown command: $first (run: webhostcli help)";; esac; }
main "$@"
